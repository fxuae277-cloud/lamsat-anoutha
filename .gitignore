node_modules
dist
# Keep the local print service's compiled output IN git so cashier PCs can
# update with `git pull` only — no `npm install` / `npm run build` needed.
!/local-print-service/dist
!/local-print-service/dist/**
.DS_Store
server/public
vite.config.ts.*
*.tar.gz
logs/*.log

# Backup artefacts produced by local-print-service/scripts/backup.ps1.
# Defaults to <repo>/BACKUPS — never commit zips/manifests.
/BACKUPS/
/local-print-service/BACKUPS/

# Secrets — NEVER commit
.env
.env.*
!.env.example
*.pem
scripts/qz-keys/*.pem
scripts/qz-keys/private.*
scripts/qz-keys/keys.*

# Print service distribution artifacts (managed separately)
local-print-service-package/
local-print-service-update.zip
print-service-v2.3.0.zip
*.zip

# IDE / tooling local config
.claude/launch.json

# Playwright test output
test-results/
tests/screenshots/

# Database backups (never commit)
*.sql
backup-pre-i18n-*
