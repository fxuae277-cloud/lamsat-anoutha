# Copy this file to `.env` and fill in real values for local development.
# In production (Railway), set these in the Variables dashboard — never commit `.env`.

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB
SESSION_SECRET=change-me
NODE_ENV=development

# QZ Tray request signing — paired with client/src/lib/qz-certificate.ts.
# Multi-line PEM is supported inside double quotes (do NOT \n-escape).
# SECURITY: NEVER expose the private key to the frontend.
# Regeneration: see scripts/qz-keys/README.md.
QZ_PRIVATE_KEY=replace-with-railway-variable

# Optional — if you need to override the bundled public certificate.
QZ_CERTIFICATE=replace-with-public-certificate-if-needed
